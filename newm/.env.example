# System
PUID=1000
PGID=1000
TZ=Your/Timezone

# Database
DB_NAME=newm
DB_USER=newm
DB_USER_PASS=
DB_ROOT_PASS=

# Storage paths
DATA_LOCATION=/home/deploy/media/nextcloud/data
TEMP_LOCATION=/home/deploy/media-temp

# Traefik
TRAEFIK_ROUTER_NAME=newm
TRAEFIK_DOMAIN=newm.yourdomain.com
TRAEFIK_CERT_RESOLVER=cloudflare
