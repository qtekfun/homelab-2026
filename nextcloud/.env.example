# System
PUID=1000
PGID=1000
TZ=Your/Timezone

# Database
DB_NAME=nextcloud
DB_USER=nextcloud
DB_USER_PASS=
DB_ROOT_PASS=

# Storage
DATA_LOCATION=/home/deploy/nextcloud/nextcloud/data
CONFIG_LOCATION=/home/deploy/nextcloud/nextcloud/config/www/nextcloud/config

# Traefik
TRAEFIK_ROUTER_NAME=nextcloud
TRAEFIK_DOMAIN=nextcloud.yourdomain.com
TRAEFIK_CERT_RESOLVER=cloudflare
