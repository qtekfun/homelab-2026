global:
  resolve_timeout: 5m

route:
  group_by: ['alertname']
  group_wait: 30s
  group_interval: 5m
  repeat_interval: 1h
  receiver: 'ntfy-webhook'

receivers:
  - name: 'ntfy-webhook'
    webhook_configs:
      - url: "https://${NTFY_DOMAIN}/${NTFY_ALERT_TOPIC}"
        http_config:
          basic_auth:
            username: '${NTFY_USER}'
            password: '${NTFY_PASSWORD}'
        send_resolved: true
