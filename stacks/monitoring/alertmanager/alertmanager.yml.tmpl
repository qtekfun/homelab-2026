global:
  resolve_timeout: 5m

route:
  group_by: ['alertname']
  group_wait: 30s
  group_interval: 5m
  repeat_interval: 1h
  receiver: 'ntfy'

receivers:
  - name: 'ntfy'
    webhook_configs:
      - url: "https://${NTFY_DOMAIN}/${NTFY_ALERT_TOPIC}?template=alertmanager"
        http_config:
          authorization:
            type: Bearer
            credentials: '${NTFY_TOKEN}'
        send_resolved: true
        max_alerts: 10
