TZ=Europe/Madrid

# AirVPN WireGuard credentials
# Get from: Client Area → Config Generator → Linux → WireGuard
WIREGUARD_PRIVATE_KEY=
WIREGUARD_PRESHARED_KEY=
WIREGUARD_ADDRESSES=

# Server selection
VPN_SERVER_COUNTRIES=Netherlands

# LAN subnet for kill-switch exception
LAN_SUBNET=192.168.188.0/24

# qBittorrent WebUI port (exposed via Gluetun)
QBIT_WEBUI_PORT=8090
