# Service-local log directories (one level deep, not root centralized logs)
*/logs/
# Centralized logs dir — track directory structure, ignore log file content
/logs/**
!/logs/*/
!/logs/*/.gitkeep

# ============================================
# LIVE CONFIGURATION DATA
# ============================================
**/config/
**/profiles/

# Exceptions — configs we want to version
